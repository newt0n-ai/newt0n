{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@spaceobject/x402",
  "type": "module",
  "version": "0.1.1",
  "description": "JavaScript SDK for the integrating x402 on 0G chain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spaceobject-xyz/spaceobject.git",
    "directory": "packages/sdk/js/x402"
  },
  "homepage": "https://github.com/spaceobject-xyz/spaceobject#readme",
  "bugs": {
    "url": "https://github.com/spaceobject-xyz/spaceobject/issues"
  },
  "keywords": [
    "spaceobject",
    "x402",
    "sdk",
    "0g",
    "micropayments",
    "payments",
    "web3",
    "evm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./server": {
      "import": {
        "types": "./dist/esm/server.d.ts",
        "default": "./dist/esm/server.js"
      },
      "require": {
        "types": "./dist/cjs/server.d.ts",
        "default": "./dist/cjs/server.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "tsup": "8.5.1",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@x402/core": "2.10.0",
    "@x402/evm": "2.10.0"
  }
}
